#!/bin/bash

# =============================================
# WireGuard Automatic Setup Script for 2 Servers
# =============================================
# This script automatically sets up a WireGuard tunnel between two Linux servers.
# It can be run on both servers and will ask for the necessary information.
# 
# Features:
#   - Installs WireGuard if not present
#   - Generates public/private keys
#   - Creates configuration files
#   - Sets up firewall rules
#   - Starts and enables WireGuard service
# =============================================

set -e  # Exit on any error

# Color codes for better output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# =============================================
# Helper Functions
# =============================================

print_step() {
    echo -e "${BLUE}[STEP]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_info() {
    echo -e "${YELLOW}[INFO]${NC} $1"
}

check_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This script must be run as root"
        exit 1
    fi
}

# =============================================
# Installation Functions
# =============================================

install_wireguard() {
    print_step "Checking/Installing WireGuard..."
    
    if command -v wg >/dev/null 2>&1; then
        print_success "WireGuard is already installed"
        return 0
    fi
    
    # Detect OS and install WireGuard
    if [[ -f /etc/debian_version ]]; then
        # Debian/Ubuntu
        apt-get update -qq
        apt-get install -y wireguard resolvconf qrencode
    elif [[ -f /etc/redhat-release ]]; then
        # CentOS/RHEL/Rocky/Alma
        if [[ -f /etc/centos-release ]] || [[ -f /etc/rocky-release ]] || [[ -f /etc/almalinux-release ]]; then
            # CentOS 8+ / Rocky / Alma
            dnf install -y epel-release
            dnf install -y wireguard-tools qrencode
        else
            # RHEL
            subscription-manager repos --enable codeready-builder-for-rhel-9-$(arch)-rpms
            dnf install -y https://dl.fedoraproject.org/pub/epel/epel-release-latest-9.noarch.rpm
            dnf install -y wireguard-tools qrencode
        fi
    elif [[ -f /etc/arch-release ]]; then
        # Arch Linux
        pacman -Sy --noconfirm wireguard-tools qrencode
    else
        print_error "Unsupported OS. Please install WireGuard manually."
        exit 1
    fi
    
    print_success "WireGuard installed successfully"
}

generate_keys() {
    print_step "Generating WireGuard keys..."
    
    # Create WireGuard directory if it doesn't exist
    mkdir -p /etc/wireguard
    chmod 700 /etc/wireguard
    
    # Generate private key
    wg genkey | tee /etc/wireguard/privatekey | wg pubkey | tee /etc/wireguard/publickey > /dev/null
    chmod 600 /etc/wireguard/privatekey
    
    PRIVATE_KEY=$(cat /etc/wireguard/privatekey)
    PUBLIC_KEY=$(cat /etc/wireguard/publickey)
    
    print_success "Keys generated successfully"
    print_info "Your public key: ${PUBLIC_KEY}"
}

get_server_info() {
    print_step "Gathering server information..."
    
    # Get server role
    while true; do
        read -p "Is this Server 1 or Server 2? (1/2): " SERVER_ROLE
        if [[ "$SERVER_ROLE" == "1" || "$SERVER_ROLE" == "2" ]]; then
            break
        else
            print_error "Please enter 1 or 2"
        fi
    done
    
    # Get public IP (try to get IPv4 first)
    PUBLIC_IP=$(curl -s -4 ifconfig.me 2>/dev/null || curl -s -4 icanhazip.com 2>/dev/null || curl -s -4 ipinfo.io/ip 2>/dev/null)
    if [[ -z "$PUBLIC_IP" ]]; then
        # Fallback to IPv6 if IPv4 fails
        PUBLIC_IP=$(curl -s -6 ifconfig.me 2>/dev/null || curl -s -6 icanhazip.com 2>/dev/null)
    fi
    
    if [[ -z "$PUBLIC_IP" ]]; then
        print_error "Could not detect public IP. Please enter it manually."
        read -p "Enter public IP address: " PUBLIC_IP
    else
        print_info "Detected public IP: ${PUBLIC_IP}"
        read -p "Is this correct? (y/n): " confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            read -p "Enter correct public IP: " PUBLIC_IP
        fi
    fi
    
    # Get network interface
    DEFAULT_INTERFACE=$(ip route | grep default | awk '{print $5}' | head -n1)
    print_info "Detected default network interface: ${DEFAULT_INTERFACE}"
    read -p "Enter network interface (press Enter to use ${DEFAULT_INTERFACE}): " NET_INTERFACE
    NET_INTERFACE=${NET_INTERFACE:-$DEFAULT_INTERFACE}
    
    # Set WireGuard IP based on server role
    if [[ "$SERVER_ROLE" == "1" ]]; then
        WG_IP="10.0.0.1"
        PEER_IP="10.0.0.2"
    else
        WG_IP="10.0.0.2"
        PEER_IP="10.0.0.1"
    fi
    
    print_info "This server will use WireGuard IP: ${WG_IP}"
    
    # Get peer information
    if [[ "$SERVER_ROLE" == "1" ]]; then
        read -p "Enter Server 2's public IP address: " PEER_PUBLIC_IP
        read -p "Enter Server 2's public key (you'll get this after running script on Server 2): " PEER_PUBLIC_KEY
        read -p "Enter Server 2's WireGuard port [51820]: " PEER_PORT
        PEER_PORT=${PEER_PORT:-51820}
    else
        read -p "Enter Server 1's public IP address: " PEER_PUBLIC_IP
        read -p "Enter Server 1's public key (you'll get this after running script on Server 1): " PEER_PUBLIC_KEY
        read -p "Enter Server 1's WireGuard port [51820]: " PEER_PORT
        PEER_PORT=${PEER_PORT:-51820}
    fi
}

create_config() {
    print_step "Creating WireGuard configuration..."
    
    # Get local port
    read -p "Enter local WireGuard port [51820]: " WG_PORT
    WG_PORT=${WG_PORT:-51820}
    
    # Create configuration file
    cat > /etc/wireguard/wg0.conf << EOF
# WireGuard configuration for Server ${SERVER_ROLE}
# Generated on $(date)

[Interface]
Address = ${WG_IP}/24
PrivateKey = ${PRIVATE_KEY}
ListenPort = ${WG_PORT}
PostUp = iptables -A FORWARD -i wg0 -j ACCEPT; iptables -t nat -A POSTROUTING -o ${NET_INTERFACE} -j MASQUERADE; ip6tables -A FORWARD -i wg0 -j ACCEPT; ip6tables -t nat -A POSTROUTING -o ${NET_INTERFACE} -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o ${NET_INTERFACE} -j MASQUERADE; ip6tables -D FORWARD -i wg0 -j ACCEPT; ip6tables -t nat -D POSTROUTING -o ${NET_INTERFACE} -j MASQUERADE

[Peer]
PublicKey = ${PEER_PUBLIC_KEY}
Endpoint = ${PEER_PUBLIC_IP}:${PEER_PORT}
AllowedIPs = ${PEER_IP}/32
PersistentKeepalive = 25
EOF
    
    chmod 600 /etc/wireguard/wg0.conf
    print_success "Configuration created at /etc/wireguard/wg0.conf"
}

setup_firewall() {
    print_step "Configuring firewall..."
    
    # Enable IP forwarding
    echo 'net.ipv4.ip_forward = 1' > /etc/sysctl.d/99-wireguard.conf
    echo 'net.ipv6.conf.all.forwarding = 1' >> /etc/sysctl.d/99-wireguard.conf
    sysctl -p /etc/sysctl.d/99-wireguard.conf
    
    # Configure firewall based on what's available
    if command -v ufw >/dev/null 2>&1; then
        # UFW
        ufw allow ${WG_PORT}/udp comment 'WireGuard'
        ufw reload
    elif command -v firewall-cmd >/dev/null 2>&1; then
        # Firewalld
        firewall-cmd --permanent --add-port=${WG_PORT}/udp
        firewall-cmd --permanent --add-masquerade
        firewall-cmd --reload
    else
        # Iptables (basic)
        iptables -A INPUT -p udp --dport ${WG_PORT} -j ACCEPT
        iptables -A FORWARD -i wg0 -j ACCEPT
        iptables -t nat -A POSTROUTING -o ${NET_INTERFACE} -j MASQUERADE
        
        # Save iptables rules (distribution specific)
        if [[ -f /etc/debian_version ]]; then
            apt-get install -y iptables-persistent
            netfilter-persistent save
        elif [[ -f /etc/redhat-release ]]; then
            service iptables save
        fi
    fi
    
    print_success "Firewall configured"
}

start_wireguard() {
    print_step "Starting WireGuard service..."
    
    # Enable and start WireGuard
    systemctl enable wg-quick@wg0
    systemctl start wg-quick@wg0
    
    # Check status
    if systemctl is-active --quiet wg-quick@wg0; then
        print_success "WireGuard is running"
    else
        print_error "WireGuard failed to start"
        systemctl status wg-quick@wg0
        exit 1
    fi
}

show_summary() {
    print_step "Setup Summary"
    
    echo -e "${GREEN}================================${NC}"
    echo -e "WireGuard has been successfully configured!"
    echo -e "${GREEN}================================${NC}"
    echo -e "Server Role:     Server ${SERVER_ROLE}"
    echo -e "Public IP:       ${PUBLIC_IP}"
    echo -e "WireGuard IP:    ${WG_IP}"
    echo -e "Public Key:      ${PUBLIC_KEY}"
    echo -e "Configuration:   /etc/wireguard/wg0.conf"
    echo -e "${GREEN}================================${NC}"
    
    # Show connection status
    echo -e "\n${YELLOW}Connection Status:${NC}"
    wg show
    
    # Test connectivity
    echo -e "\n${YELLOW}Testing connectivity to peer (${PEER_IP})...${NC}"
    if ping -c 3 ${PEER_IP} >/dev/null 2>&1; then
        print_success "Successfully connected to peer!"
    else
        print_info "Waiting for peer to become available..."
        print_info "Run 'ping ${PEER_IP}' after setting up the other server"
    fi
    
    # Show QR code for mobile clients (optional)
    if command -v qrencode >/dev/null 2>&1; then
        echo -e "\n${YELLOW}QR Code for mobile clients (if needed):${NC}"
        qrencode -t ansiutf8 < /etc/wireguard/wg0.conf 2>/dev/null || echo "Could not generate QR code"
    fi
}

# =============================================
# Main Script Execution
# =============================================

main() {
    echo -e "${GREEN}"
    echo "╔══════════════════════════════════════════╗"
    echo "║     WireGuard Auto-Setup for 2 Servers   ║"
    echo "╚══════════════════════════════════════════╝"
    echo -e "${NC}"
    
    # Check if running as root
    check_root
    
    # Install WireGuard if needed
    install_wireguard
    
    # Generate keys
    generate_keys
    
    # Get server information
    get_server_info
    
    # Create configuration
    create_config
    
    # Setup firewall
    setup_firewall
    
    # Start WireGuard
    start_wireguard
    
    # Show summary
    show_summary
    
    print_success "Setup completed successfully!"
    
    # Instructions for the other server
    echo -e "\n${YELLOW}=== Next Steps ===${NC}"
    if [[ "$SERVER_ROLE" == "1" ]]; then
        echo "1. Run this script on Server 2"
        echo "2. When prompted for Server 1's public key, use: ${PUBLIC_KEY}"
        echo "3. After Server 2 is configured, the tunnel should be established automatically"
    else
        echo "1. Run this script on Server 1 (if not done yet)"
        echo "2. When prompted for Server 2's public key, use: ${PUBLIC_KEY}"
        echo "3. After both servers are configured, the tunnel should be established automatically"
    fi
}

# Run main function
main